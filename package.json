{
  "name": "@rosariomoscato/turbodev",
  "version": "0.0.8",
  "type": "module",
  "description": "Terminal-based AI coding agent",
  "author": "Rosario Moscato",
  "license": "CC-BY-NC-SA-4.0",
  "keywords": [
    "ai",
    "agent",
    "cli",
    "terminal",
    "coding",
    "llm",
    "openrouter",
    "chatbot",
    "tui"
  ],
  "homepage": "https://rosmoscato.xyz/turbodev/",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/rosariomoscato/TurboDev.git"
  },
  "bugs": {
    "url": "https://github.com/rosariomoscato/TurboDev/issues"
  },
  "bin": {
    "turbodev": "dist/index.js"
  },
  "scripts": {
    "dev": "tsx src/index.tsx",
    "dev:watch": "tsx watch --exclude '.turbodev' src/index.tsx",
    "build": "tsup",
    "start": "node dist/index.js",
    "test": "vitest run",
    "docs:dev": "vitepress dev docs",
    "docs:build": "vitepress build docs",
    "docs:preview": "vitepress preview docs"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.0.4",
    "chalk": "^5.3.0",
    "gray-matter": "^4.0.3",
    "ink": "^4.4.1",
    "ink-select-input": "^5.0.0",
    "ink-spinner": "^5.0.0",
    "ink-text-input": "^5.0.1",
    "openai": "^4.20.1",
    "react": "^18.2.0",
    "simple-git": "^3.36.0"
  },
  "devDependencies": {
    "@types/node": "^20.11.0",
    "@types/react": "^18.2.0",
    "tsup": "^8.0.0",
    "tsx": "^4.7.0",
    "typescript": "^5.3.0",
    "vitepress": "^1.6.4",
    "vitest": "^4.1.8"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
